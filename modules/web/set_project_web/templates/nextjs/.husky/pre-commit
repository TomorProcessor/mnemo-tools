#!/usr/bin/env sh
# Web project type pre-commit hook.
# Runs lint over staged files via lint-staged. ESLint catches:
#   - raw <img> tags (@next/next/no-img-element)
#   - hardcoded JSX strings inside src/app/[locale]/** (i18next/no-literal-string)
# Only staged files are checked, so a previously-merged file with violations
# does not block unrelated future commits.
#
# i18n key-completeness (`pnpm check:i18n`) is intentionally NOT run here:
# it scans the whole project and would block commits whenever any pre-existing
# missing translation key remains anywhere in src/. Use `pnpm check:i18n`
# manually as a self-check before submitting; the verify pipeline still
# enforces it server-side as a gate.

set -e

pnpm lint-staged

